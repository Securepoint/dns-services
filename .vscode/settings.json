{
    "json.schemas": [
        {
            "fileMatch": [
                "services/*.json"
            ],
            "url": "./schemas/services.schema.json"
        },
        {
            "fileMatch": [
                "countries/*.json"
            ],
            "url": "./schemas/countries.schema.json"
        }
    ],
    "json.validate.enable": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
}
